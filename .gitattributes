# Normalize line endings: text files stored as LF in the repo.
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.ps1   text eol=lf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary assets (never touched / diffed as text)
*.png   binary
*.ttf   binary
*.npz   binary
*.grib  binary
*.grib2 binary
*.spc   binary
*.buf   binary
*.OAX   binary
